# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# source data (API에서 수집한 원본 — 레포에 올릴 필요 없음)
/source-data/

# scripts (일회성 유틸리티 — generate-article-json.mjs는 빌드에 필수)
/scripts/
!/scripts/generate-article-json.mjs
!/scripts/fix-bracket-chunks.mjs

# tmp (임시 파일)
/tmp/

# 빌드 시 자동 생성되는 JSON 데이터
/public/data/

# 스크린샷 / 이미지 캡처
*.png
*.jpeg

# 루트 임시 스크립트
/add_spokes.js
/gen_spokes.js
/test_run.js
/tmp_*.js
/spoke_data*.json
/nul

# 백업 파일
/data/*.backup.ts
/data/*.old.ts

# IDE / 도구
.vscode/
.playwright-mcp/
.claude/
_workspace/
